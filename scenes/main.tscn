[gd_scene load_steps=2 format=3 uid="uid://clickergamemain0"]

[ext_resource type="Script" path="res://scripts/main.gd" id="1_main"]

[node name="Main" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.12, 0.14, 0.2, 1)

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
offset_left = 40.0
offset_top = 60.0
offset_right = -40.0
offset_bottom = -60.0
theme_override_constants/separation = 24
alignment = 1

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Clicker Game Demo"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48

[node name="ScoreLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 96

[node name="PerSecondLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "0 / sec"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 28

[node name="ClickButton" type="Button" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
text = "CLICK!"
theme_override_font_sizes/font_size = 64

[node name="UpgradePanel" type="VBoxContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="UpgradeClick" type="Button" parent="VBox/UpgradePanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Upgrade Click (+1) — Cost: 10"
theme_override_font_sizes/font_size = 24

[node name="BuyAuto" type="Button" parent="VBox/UpgradePanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Buy Auto-Clicker (+1/sec) — Cost: 25"
theme_override_font_sizes/font_size = 24

[node name="AutoTimer" type="Timer" parent="."]
wait_time = 1.0
autostart = true

[connection signal="pressed" from="VBox/ClickButton" to="." method="_on_click_pressed"]
[connection signal="pressed" from="VBox/UpgradePanel/UpgradeClick" to="." method="_on_upgrade_click_pressed"]
[connection signal="pressed" from="VBox/UpgradePanel/BuyAuto" to="." method="_on_buy_auto_pressed"]
[connection signal="timeout" from="AutoTimer" to="." method="_on_auto_timer_timeout"]
