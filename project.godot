; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Clicker Game Demo"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
DataRegistry="*res://scripts/autoload/data_registry.gd"
GameState="*res://scripts/autoload/game_state.gd"
ReactionDispatcher="*res://scripts/autoload/reaction_dispatcher.gd"
LocaleService="*res://scripts/autoload/locale_service.gd"
BGMService="*res://scripts/autoload/bgm_service.gd"
DebugHUD="*res://addons/runtime_debug_hud/debug_hud.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/asset_audit/plugin.cfg", "res://addons/i18n_audit/plugin.cfg", "res://addons/runtime_debug_hud/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://translations/strings.en.translation", "res://translations/strings.ja.translation", "res://translations/strings.zh_CN.translation", "res://translations/dialogues/lemuen.en.translation", "res://translations/dialogues/lemuen.ja.translation", "res://translations/dialogues/lemuen.zh_CN.translation")
locale/fallback="ja"
locale/test=""

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
